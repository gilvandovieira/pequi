{
  "name": "@pequi/log",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./pure": "./src/backends/pure.ts",
    "./native": "./src/backends/native.ts"
  },
  "publish": {
    "include": [
      "mod.ts",
      "src/**/*.ts",
      "prebuilt/**",
      "README.md",
      "BENCHMARKS.md",
      "COMPATIBILITY.md",
      "NATIVE.md",
      "ROADMAP.md",
      "jsr.json",
      "deno.json"
    ]
  },
  "tasks": {
    "check": "deno check mod.ts tests/**/*.ts bench/**/*.ts scripts/**/*.ts",
    "test": "deno test --allow-read --allow-write --allow-env=NODE_V8_COVERAGE --allow-sys=hostname",
    "test:native": "deno test --allow-read --allow-write --allow-ffi tests/integration/native-loader.test.ts",
    "bench": "deno bench --allow-read --allow-write",
    "bench:native": "deno bench --allow-read --allow-write --allow-ffi bench/**/*.bench.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "native:build": "deno run --allow-run --allow-read --allow-write scripts/build-native.ts",
    "native:check": "deno run --allow-read --allow-ffi scripts/check-native.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.14"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
